{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "max",
  "permissions": {
    "deny": [
      "Bash(git commit *--no-verify*)",
      "Bash(git push *--no-verify*)",
      "Bash(git push *--force*)",
      "Bash(git push *-f*)",
      "Bash(rm -rf:*)"
    ],
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git push origin*)",
      "Bash(git pull)",
      "Bash(git pull:*)",
      "Bash(git reset *origin/main*)",
      "Bash(git restore:*)",
      "Bash(./scripts/build.sh)",
      "Bash(./scripts/build.sh:*)",
      "Bash(./scripts/verify-deploy.sh:*)",
      "Bash(./scripts/lint-diary.sh:*)",
      "Bash(scripts/build.sh)",
      "Bash(scripts/build.sh:*)",
      "Bash(scripts/verify-deploy.sh:*)",
      "Bash(scripts/lint-diary.sh:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(./scripts/local-snapshot.sh)",
      "Bash(./scripts/local-snapshot.sh:*)",
      "Bash(scripts/local-snapshot.sh)",
      "Bash(scripts/local-snapshot.sh:*)"
    ]
  }
}
